
# Supabase (get from: Supabase dashboard → Settings → Database → JDBC)
DB_URL=jdbc:postgresql://aws-0-region.pooler.supabase.com:6543/postgres
DB_USERNAME=postgres.yourprojectref
DB_PASSWORD=your-supabase-password

# Spotflow (get from: Spotflow dashboard → API Keys → Test mode)
SPOTFLOW_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SPOTFLOW_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App (Render sets PORT automatically, you don't need to set this)
PORT=8080
